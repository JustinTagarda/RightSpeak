<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>Resources\Icons\RightSpeak.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Speech" Version="10.0.6" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="RightSpeak.NativeHost\**\*.cs" />
    <EmbeddedResource Remove="RightSpeak.NativeHost\**\*" />
    <None Remove="RightSpeak.NativeHost\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Icons\RightSpeak.ico" />
  </ItemGroup>

</Project>
