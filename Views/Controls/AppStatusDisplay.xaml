<UserControl x:Class="RightSpeak.Views.Controls.AppStatusDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#DD1E1E1E"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Visibility="{Binding IsNoUpdateToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="No update available"
                       FontSize="11"
                       Foreground="White" />
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <TextBlock Text="{Binding ModeText}"
                       FontWeight="Bold"
                       Cursor="Arrow"
                       ToolTip="{Binding ModeTooltip}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Cursor" Value="Arrow" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsModeClickable}" Value="True">
                                <Setter Property="Cursor" Value="{x:Static input:Cursors.Hand}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding UpgradeCommand}" />
                </TextBlock.InputBindings>
            </TextBlock>
            <TextBlock Text="   " />
            <TextBlock Text="{Binding VersionText}"
                       Cursor="Hand"
                       ToolTip="Click to check for updates.">
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding CheckForUpdateCommand}" />
                </TextBlock.InputBindings>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
