<UserControl x:Class="RightSpeak.Views.Controls.AppStatusDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <Grid>
        <Popup DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
               IsOpen="{Binding IsNoUpdateToastVisible}"
               PlacementTarget="{Binding ElementName=VersionTextBlock}"
               Placement="Top"
               AllowsTransparency="True"
               StaysOpen="True"
               HorizontalOffset="0"
               VerticalOffset="-6">
            <Border Background="#DD1E1E1E"
                    CornerRadius="4"
                    Padding="8,4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
                <TextBlock Text="No update available"
                           FontSize="11"
                           Foreground="White" />
            </Border>
        </Popup>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <TextBlock Text="{Binding ModeText}"
                       FontWeight="Bold"
                       Cursor="Arrow"
                       ToolTip="{Binding ModeTooltip}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Cursor" Value="Arrow" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsModeClickable}" Value="True">
                                <Setter Property="Cursor" Value="{x:Static input:Cursors.Hand}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding UpgradeCommand}" />
                </TextBlock.InputBindings>
            </TextBlock>
            <TextBlock Text="   " />
            <TextBlock Text="Restore"
                       Cursor="Hand"
                       ToolTip="Click to restore purchases.">
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding RestorePurchaseCommand}" />
                </TextBlock.InputBindings>
            </TextBlock>
            <TextBlock Text="   " />
            <TextBlock x:Name="VersionTextBlock"
                       Text="{Binding VersionText}"
                       Cursor="Hand"
                       ToolTip="Click to check for updates.">
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding CheckForUpdateCommand}" />
                </TextBlock.InputBindings>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
