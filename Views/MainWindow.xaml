<Window x:Class="RightSpeak.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="RightSpeak"
        Icon="/Resources/Icons/RightSpeak.ico"
        Width="550"
        WindowStartupLocation="Manual"
        Height="700"
        MinWidth="550"
        MinHeight="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.TaskbarItemInfo>
        <shell:TaskbarItemInfo ProgressState="{Binding TaskbarProgressState}"
                               ProgressValue="{Binding TaskbarProgressValue}" />
    </Window.TaskbarItemInfo>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style x:Key="CollapsibleTextStyle" TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TitleBarForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarButtonHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarButtonPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarCloseButtonHoverBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TitleBarCloseButtonForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarCloseButtonPressedBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TitleBarCloseButtonForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCompactCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource FooterTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid VerticalAlignment="Center" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Box"
                                    Grid.Column="0"
                                    Width="14"
                                    Height="14"
                                    CornerRadius="3"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource InputBorderBrush}"
                                    Background="{DynamicResource InputBackgroundBrush}" />

                            <Path x:Name="CheckMark"
                                  Grid.Column="0"
                                  Width="8"
                                  Height="8"
                                  Stretch="Uniform"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stroke="{DynamicResource InputForegroundBrush}"
                                  Data="M 1 4 L 3.2 6.2 L 7 2.2"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />

                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterThemeComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterThemeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource FooterTextBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource FooterTextBrush}" />
            <Setter Property="BorderThickness" Value="0.25" />
            <Setter Property="Padding" Value="6,2,8,2" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource FooterThemeComboBoxToggleButtonStyle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Stretch"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Margin="{TemplateBinding Padding}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Text="{TemplateBinding SelectionBoxItem}"
                                               Foreground="{TemplateBinding Foreground}"
                                               TextAlignment="Left"
                                               TextTrimming="CharacterEllipsis" />
                                    <Path Grid.Column="1"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"
                                          Fill="{TemplateBinding Foreground}"
                                          Data="M 0 0 L 4 4 L 8 0 Z" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border Background="{DynamicResource CardBackgroundBrush}"
                                            BorderBrush="{DynamicResource FooterTextBrush}"
                                            BorderThickness="0.25"
                                            CornerRadius="4" />
                                    <ScrollViewer Margin="4"
                                                  Padding="0,0,1,0"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="0"
            Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="32"
                    BorderBrush="{DynamicResource TitleBarBorderBrush}"
                    BorderThickness="0"
                    Background="{DynamicResource TitleBarBackgroundBrush}"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Width="16"
                           Height="16"
                           Margin="10,0,8,0"
                           VerticalAlignment="Center"
                           Source="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Icon}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource TitleBarForegroundBrush}"
                                   Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" />
                        <CheckBox Margin="20,0,0,0"
                                  Style="{StaticResource TitleBarCompactCheckBoxStyle}"
                                  Content="Always on top"
                                  Checked="AlwaysOnTopCheckBox_OnCheckedChanged"
                                  Unchecked="AlwaysOnTopCheckBox_OnCheckedChanged"
                                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Topmost, Mode=TwoWay}" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            ToolTip="Minimize">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE921;" />
                    </Button>
                    <Button Grid.Column="3"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_OnClick"
                            ToolTip="Maximize or restore">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE922;" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="4"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_OnClick"
                            ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE8BB;" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="12,6,12,9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,6"
                IsEnabled="{Binding IsInputReadEnabled}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Read Input"
                           Style="{StaticResource SectionHeaderStyle}" />
                <TextBlock Grid.Row="1"
                           Text="Type or paste text below, then start reading."
                           Margin="0,0,0,5"
                           Style="{StaticResource SubtleTextStyle}" />

                <TextBox Grid.Row="2"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Style="{StaticResource InputTextBoxStyle}"
                         VerticalAlignment="Stretch"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="3"
                            Margin="0,8,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button MinWidth="85"
                            Content="Read"
                            Command="{Binding ReadCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                    <Button MinWidth="85"
                            Content="Clear"
                            Command="{Binding ClearCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button MinWidth="85"
                            Content="{Binding PauseButtonText}"
                            IsEnabled="{Binding IsPauseEnabled}"
                            Click="OnInputPauseButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button MinWidth="85"
                            Content="Stop"
                            IsEnabled="{Binding IsStopEnabled}"
                            Click="OnInputStopButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,6"
                IsEnabled="{Binding IsExternalReadSectionEnabled}">
            <StackPanel>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Read From Other App"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Text="{Binding FocusedWindowText}"
                               Style="{StaticResource SubtleTextStyle}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                </Grid>
                <TextBlock Text="Read selected text or full documents from the active app."
                           Margin="0,0,0,6"
                           Style="{StaticResource SubtleTextStyle}" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button MinWidth="85"
                            Margin="0,0,8,0"
                            Content="Read Selected Text"
                            IsEnabled="{Binding IsExternalReadsEnabled}"
                            Click="OnReadSelectedTextButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button MinWidth="85"
                            Margin="0,0,8,0"
                            Content="Read Document"
                            IsEnabled="{Binding IsExternalReadsEnabled}"
                            Click="OnReadDocumentButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button MinWidth="85"
                            Margin="0,0,8,0"
                            Content="{Binding PauseButtonText}"
                            IsEnabled="{Binding IsPauseEnabled}"
                            Click="OnExternalPauseButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button MinWidth="85"
                            Content="{Binding ExternalReadActionText}"
                            IsEnabled="{Binding IsStopEnabled}"
                            Click="OnExternalStopButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3"
              Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="0,0,4,0">
                <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Voice model"
                                       Style="{StaticResource SectionHeaderStyle}" />

                            <ComboBox Height="30"
                                      Margin="0,0,0,8"
                                      VerticalContentAlignment="Center"
                                      Style="{DynamicResource InputComboBoxStyle}"
                                      ItemsSource="{Binding VoiceOptions}"
                                      SelectedItem="{Binding SelectedVoiceOption, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,0,0,8"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           Text="Rate"
                                           Margin="0,0,8,0" />
                                <Slider Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Minimum="-10"
                                        Maximum="10"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding SpeechRate, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="2"
                                           Width="24"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           Text="{Binding SpeechRate}" />
                            </Grid>

                            <StackPanel Orientation="Horizontal"
                                        IsEnabled="{Binding IsVoiceModelButtonsEnabled}"
                                        HorizontalAlignment="Left">
                                <Button Width="84"
                                        Margin="0,0,8,0"
                                        Content="Manage"
                                        Click="OnManageVoicesButtonClick"
                                        Style="{DynamicResource SecondaryButtonStyle}" />
                                <Button Width="84"
                                        Content="Preview"
                                        Command="{Binding PreviewVoiceCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Style="{StaticResource CardStyle}"
                    Margin="4,0,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hotkeys"
                                   Style="{StaticResource SectionHeaderStyle}" />
                        <Button Grid.Column="1"
                                Width="18"
                                Height="18"
                                MinHeight="0"
                                Padding="0"
                                Margin="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Content="↺"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding ResetHotkeysCommand}"
                                ToolTip="Reset hotkeys to defaults" />
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <RadioButton Content="Alt+Shift"
                                     Margin="0,0,10,0"
                                     IsChecked="{Binding IsAltShiftModifierSelected}" />
                        <RadioButton Content="Ctrl+Shift"
                                     Margin="0,0,10,0"
                                     IsChecked="{Binding IsCtrlShiftModifierSelected}" />
                        <RadioButton Content="Ctrl+Alt"
                                     IsChecked="{Binding IsCtrlAltModifierSelected}" />
                    </StackPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   VerticalAlignment="Center"
                                   Text="Read selected"
                                   Margin="0,0,6,2" />
                        <ComboBox Grid.Row="0"
                                  Grid.Column="2"
                                  Height="30"
                                  Margin="0,0,0,2"
                                  VerticalContentAlignment="Center"
                                  Style="{DynamicResource InputComboBoxStyle}"
                                  ItemsSource="{Binding HotkeyKeyOptions}"
                                  SelectedItem="{Binding ReadSelectedHotkeyKey, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding HotkeyModifierLabel, StringFormat={}{0}+}"
                                   Margin="0,0,4,2"
                                   Style="{StaticResource SubtleTextStyle}" />

                        <TextBlock Grid.Row="1"
                                   VerticalAlignment="Center"
                                   Text="Read document"
                                   Margin="0,0,6,2" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="2"
                                  Height="30"
                                  Margin="0,0,0,2"
                                  VerticalContentAlignment="Center"
                                  Style="{DynamicResource InputComboBoxStyle}"
                                  ItemsSource="{Binding HotkeyKeyOptions}"
                                  SelectedItem="{Binding ReadDocumentHotkeyKey, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding HotkeyModifierLabel, StringFormat={}{0}+}"
                                   Margin="0,0,4,2"
                                   Style="{StaticResource SubtleTextStyle}" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Text="Stop"
                                   Margin="0,0,6,0" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="2"
                                  Height="30"
                                  VerticalContentAlignment="Center"
                                  Style="{DynamicResource InputComboBoxStyle}"
                                  ItemsSource="{Binding HotkeyKeyOptions}"
                                  SelectedItem="{Binding StopHotkeyKey, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding HotkeyModifierLabel, StringFormat={}{0}+}"
                                   Margin="0,0,4,0"
                                   Style="{StaticResource SubtleTextStyle}" />
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="{DynamicResource StatusBackgroundBrush}"
                BorderBrush="{DynamicResource StatusBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,5"
                VerticalAlignment="Center">
            <Grid VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Grid.Row="0"
                           Foreground="{DynamicResource StatusForegroundBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           Text="{Binding HotkeyModifierWarningMessage}"
                           Margin="0,2,0,0"
                           Foreground="{DynamicResource WarningTextBrush}"
                           TextWrapping="Wrap"
                           Style="{StaticResource CollapsibleTextStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="5"
              Margin="2,13,2,0"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="© 2026 JustinTagarda. All rights reserved."
                       Foreground="{DynamicResource FooterTextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsFooterStaticInfoVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Border Grid.Column="1"
                    Margin="18,0"
                    Padding="10,4"
                    VerticalAlignment="Center"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsFooterUpdateCardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Width="210">
                    <TextBlock Text="{Binding UpdateStageText}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource FooterTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding UpdateStatusMessage}"
                               Margin="0,1,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <ProgressBar Margin="0,4,0,0"
                                 Height="4"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding UpdateProgressPercent, Mode=OneWay}"
                                 Visibility="{Binding IsUpdateProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Visibility="{Binding IsFooterStaticInfoVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Theme"
                           Foreground="{DynamicResource FooterTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <ComboBox Height="24"
                          Padding="4,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          VerticalContentAlignment="Center"
                          Style="{StaticResource FooterThemeComboBoxStyle}"
                          ItemsSource="{Binding ThemeOptions}"
                          SelectedItem="{Binding SelectedTheme, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <TextBlock Grid.Column="3"
                       Text="{Binding AppVersionText, RelativeSource={RelativeSource AncestorType=Window}}"
                       Foreground="{DynamicResource FooterTextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
        </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
