<Window x:Class="RightSpeak.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="RightSpeak"
        Icon="/Resources/Icons/RightSpeak.ico"
        Width="600"
        WindowStartupLocation="Manual"
        Height="700"
        MinWidth="600"
        MinHeight="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.TaskbarItemInfo>
        <shell:TaskbarItemInfo ProgressState="{Binding TaskbarProgressState}"
                               ProgressValue="{Binding TaskbarProgressValue}" />
    </Window.TaskbarItemInfo>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style x:Key="CollapsibleTextStyle" TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TitleBarForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarButtonHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarButtonPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarCloseButtonHoverBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TitleBarCloseButtonForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarCloseButtonPressedBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TitleBarCloseButtonForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="0"
            Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="32"
                    BorderBrush="{DynamicResource TitleBarBorderBrush}"
                    BorderThickness="0"
                    Background="{DynamicResource TitleBarBackgroundBrush}"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Width="16"
                           Height="16"
                           Margin="10,0,8,0"
                           VerticalAlignment="Center"
                           Source="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Icon}" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TitleBarForegroundBrush}"
                               Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" />

                    <Button Grid.Column="2"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            ToolTip="Minimize">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE921;" />
                    </Button>
                    <Button Grid.Column="3"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_OnClick"
                            ToolTip="Maximize or restore">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE922;" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="4"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_OnClick"
                            ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE8BB;" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="12,6,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,6"
                IsEnabled="{Binding IsManualReadEnabled}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Manual Read"
                           Style="{StaticResource SectionHeaderStyle}" />
                <TextBlock Grid.Row="1"
                           Text="Type or paste text below, then start reading."
                           Margin="0,0,0,5"
                           Style="{StaticResource SubtleTextStyle}" />

                <TextBox Grid.Row="2"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Style="{StaticResource InputTextBoxStyle}"
                         VerticalAlignment="Stretch"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="3"
                            Margin="0,8,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Width="146"
                            Content="Read Manual Text"
                            Command="{Binding ReadCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                    <Button Width="78"
                            Content="Clear"
                            Command="{Binding ClearCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button Width="88"
                            Content="Stop"
                            IsEnabled="{Binding IsStopEnabled}"
                            Click="OnManualStopButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,6">
            <StackPanel>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Read From Other App"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Text="{Binding FocusedWindowText}"
                               Style="{StaticResource SubtleTextStyle}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                </Grid>
                <TextBlock Text="Read selected text or full documents from the active app."
                           Margin="0,0,0,6"
                           Style="{StaticResource SubtleTextStyle}" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Width="154"
                            Margin="0,0,8,0"
                            Content="Read Selected Text"
                            IsEnabled="{Binding IsExternalReadsEnabled}"
                            Click="OnReadSelectedTextButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button Width="128"
                            Margin="0,0,8,0"
                            Content="Read Document"
                            IsEnabled="{Binding IsExternalReadsEnabled}"
                            Click="OnReadDocumentButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button Width="128"
                            Content="Stop Reading"
                            IsEnabled="{Binding IsStopEnabled}"
                            Click="OnExternalStopButtonClick"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3"
              Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,8"
                            Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Voice model"
                                       Style="{StaticResource SectionHeaderStyle}" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ComboBox Height="30"
                                          VerticalContentAlignment="Center"
                                          Style="{DynamicResource InputComboBoxStyle}"
                                          ItemsSource="{Binding VoiceOptions}"
                                          SelectedItem="{Binding SelectedVoiceOption, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        Width="84"
                                        Margin="8,0,0,0"
                                        Content="Manage"
                                        Click="OnManageVoicesButtonClick"
                                        Style="{DynamicResource SecondaryButtonStyle}" />
                            </Grid>

                            <Grid Margin="0,0,0,8"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           Text="Rate"
                                           Margin="0,0,8,0" />
                                <Slider Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Minimum="-10"
                                        Maximum="10"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding SpeechRate, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="2"
                                           Width="24"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           Text="{Binding SpeechRate}" />
                                <Button Grid.Column="3"
                                        Width="84"
                                        Margin="8,0,0,0"
                                        Content="Preview"
                                        Command="{Binding PreviewVoiceCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardStyle}">
                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       Text="Theme"
                                       Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      Width="144"
                                      Height="30"
                                      VerticalContentAlignment="Center"
                                      Style="{DynamicResource InputComboBoxStyle}"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    Style="{StaticResource CardStyle}"
                    Margin="8,0,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hotkeys"
                                   Style="{StaticResource SectionHeaderStyle}" />
                        <Button Grid.Column="1"
                                Width="18"
                                Height="18"
                                MinHeight="0"
                                Padding="0"
                                Margin="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Content="↺"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding ResetHotkeysCommand}"
                                ToolTip="Reset hotkeys to defaults" />
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <RadioButton Content="Alt+Shift"
                                     Margin="0,0,10,0"
                                     IsChecked="{Binding IsAltShiftModifierSelected}" />
                        <RadioButton Content="Ctrl+Shift"
                                     Margin="0,0,10,0"
                                     IsChecked="{Binding IsCtrlShiftModifierSelected}" />
                        <RadioButton Content="Ctrl+Alt"
                                     IsChecked="{Binding IsCtrlAltModifierSelected}" />
                    </StackPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   VerticalAlignment="Center"
                                   Text="Read selected"
                                   Margin="0,0,6,2" />
                        <ComboBox Grid.Row="0"
                                  Grid.Column="2"
                                  Height="30"
                                  Margin="0,0,0,2"
                                  VerticalContentAlignment="Center"
                                  Style="{DynamicResource InputComboBoxStyle}"
                                  ItemsSource="{Binding HotkeyKeyOptions}"
                                  SelectedItem="{Binding ReadSelectedHotkeyKey, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding HotkeyModifierLabel, StringFormat={}{0}+}"
                                   Margin="0,0,4,2"
                                   Style="{StaticResource SubtleTextStyle}" />

                        <TextBlock Grid.Row="1"
                                   VerticalAlignment="Center"
                                   Text="Read document"
                                   Margin="0,0,6,2" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="2"
                                  Height="30"
                                  Margin="0,0,0,2"
                                  VerticalContentAlignment="Center"
                                  Style="{DynamicResource InputComboBoxStyle}"
                                  ItemsSource="{Binding HotkeyKeyOptions}"
                                  SelectedItem="{Binding ReadDocumentHotkeyKey, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding HotkeyModifierLabel, StringFormat={}{0}+}"
                                   Margin="0,0,4,2"
                                   Style="{StaticResource SubtleTextStyle}" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Text="Stop"
                                   Margin="0,0,6,0" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="2"
                                  Height="30"
                                  VerticalContentAlignment="Center"
                                  Style="{DynamicResource InputComboBoxStyle}"
                                  ItemsSource="{Binding HotkeyKeyOptions}"
                                  SelectedItem="{Binding StopHotkeyKey, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding HotkeyModifierLabel, StringFormat={}{0}+}"
                                   Margin="0,0,4,0"
                                   Style="{StaticResource SubtleTextStyle}" />
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="{DynamicResource StatusBackgroundBrush}"
                BorderBrush="{DynamicResource StatusBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,5"
                VerticalAlignment="Center">
            <Grid VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Grid.Row="0"
                           Foreground="{DynamicResource StatusForegroundBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           Text="{Binding HotkeyModifierWarningMessage}"
                           Margin="0,2,0,0"
                           Foreground="{DynamicResource WarningTextBrush}"
                           TextWrapping="Wrap"
                           Style="{StaticResource CollapsibleTextStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="5"
              Margin="2,10,2,0"
              VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="© 2026 JustinTagarda. All rights reserved."
                       Foreground="{DynamicResource FooterTextBrush}"
                       FontSize="12"
                       VerticalAlignment="Bottom" />
            <Border Grid.Column="1"
                    Margin="18,0"
                    Padding="10,4"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsUpdateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Width="210">
                    <TextBlock Text="{Binding UpdateStageText}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource FooterTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding UpdateStatusMessage}"
                               Margin="0,1,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <ProgressBar Margin="0,4,0,0"
                                 Height="4"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding UpdateProgressPercent, Mode=OneWay}"
                                 Visibility="{Binding IsUpdateProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Border>
            <TextBlock Grid.Column="2"
                       Text="{Binding AppVersionText, RelativeSource={RelativeSource AncestorType=Window}}"
                       Foreground="{DynamicResource FooterTextBrush}"
                       FontSize="12"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Right" />
        </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
