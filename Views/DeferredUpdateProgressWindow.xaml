<Window x:Class="RightSpeak.Views.DeferredUpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Applying update"
        Width="420"
        Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Topmost="True"
        Closing="OnClosing">
    <Border Padding="20"
            Background="{DynamicResource WindowBackgroundBrush}">
        <StackPanel>
            <TextBlock x:Name="StatusTextBlock"
                       Text="Applying update..."
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
            <ProgressBar x:Name="UpdateProgressBar"
                         Margin="0,16,0,0"
                         Height="8"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="True" />
            <TextBlock x:Name="DetailTextBlock"
                       Margin="0,12,0,0"
                       Text="Please wait while RightSpeak finishes the Microsoft Store update."
                       TextWrapping="Wrap"
                       Opacity="0.8" />
        </StackPanel>
    </Border>
</Window>
