<Window x:Class="RightSpeak.Views.StoreUpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App Update"
        Width="420"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">
    <Border Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Text="{Binding StoreUpdateProgressPhase}" />
            <ProgressBar Grid.Row="1"
                         Margin="0,8,0,0"
                         Height="12"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding StoreUpdateProgressPercent}" />
            <TextBlock Grid.Row="2"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Text="{Binding StoreUpdateProgressDetail}" />
            <TextBlock Grid.Row="3"
                       Margin="0,8,0,0"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Text="{Binding StoreUpdateProgressResult}" />
            <TextBlock Grid.Row="4"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       Text="You can close this window after update reaches a terminal state."
                       TextWrapping="Wrap" />
        </Grid>
    </Border>
</Window>
